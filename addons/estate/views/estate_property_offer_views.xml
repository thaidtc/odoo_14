<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="estate_property_offer_tree" model="ir.ui.view">
        <field name="name">estate.property.offer.tree</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <tree string="Property Offers" editable="top" decoration-success="status == 'accepted'"
                  decoration-danger="status == 'refused'">
                <button name="action_accept_offer" string="Accept" type="object" class="btn-success" attrs="{'invisible': [('status', '!=', 'False')]}"/>
                <button name="action_refuse_offer" string="Refuse" type="object" class="btn-danger" attrs="{'invisible': [('status', '!=', 'False')]}"/>

                <field name="property_id"/>
                <field name="property_type_id"/>
                <field name="partner_id"/>
                <field name="price"/>
                <field name="status"/>
                <field name="date_deadline"/>

                <field name="create_date" string="Created Date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="estate_property_offer_form" model="ir.ui.view">
        <field name="name">estate.property.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept_offer" string="Accept Offer" type="object" class="btn-success" attrs="{'invisible': [('status', '!=', 'False')]}"/>
                    <button name="action_refuse_offer" string="Refuse Offer" type="object" class="btn-danger" attrs="{'invisible': [('status', '!=', 'False')]}"/>
                </header>

                <sheet>
                    <group>
                        <field name="property_id"/>
                        <field name="property_type_id"/>
                        <field name="partner_id"/>
                        <field name="price"/>
                        <field name="validity"/>
                    </group>
                    <group>
                        <field name="status"/>
                        <field name="date_deadline"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offers</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>