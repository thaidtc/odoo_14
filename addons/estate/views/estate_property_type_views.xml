<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="estate_property_type_tree" model="ir.ui.view">
        <field name="name">estate.property.type.tree</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="sequence"/>
                <field name="offer_count" string="Number of Offers"/>
                <button name="action_view_offers" type="object" string="View Offers" class="btn-primary"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="estate_property_type_form" model="ir.ui.view">
        <field name="name">estate.property.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="offer_count" string="Number of Offers"/>
                    </group>

                    <notebook>
                        <page string="Properties">
                            <field name="property_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="expected_price"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Offers">
                            <field name="offer_ids" nolabel="1">
                                <tree>
                                    <field name="property_id"/>
                                    <field name="partner_id"/>
                                    <field name="price"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                    <footer>
                        <button name="action_view_offers" type="object" string="View Offers Statistics" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="estate_property_type_action" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>