<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="hospital_patient_seq" model="ir.sequence">
      <field name="name">Hospital Patient Sequence</field>
      <field name="code">hospital.patient</field>
      <field name="prefix">HP</field>
      <field name="padding">5</field>
      <field eval="False" name="company_id"/>
    </record>

    <record id="hospital_appointment_seq" model="ir.sequence">
      <field name="name">Hospital Appointment Sequence</field>
      <field name="code">hospital.appointment</field>
      <field name="prefix">OT</field>
      <field name="padding">5</field>
      <field eval="False" name="company_id"/>
    </record>
  </data>
</odoo>