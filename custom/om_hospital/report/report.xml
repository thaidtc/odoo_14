<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="patient_details_action_report" model="ir.actions.report">
        <field name="name">Patient Details</field>
        <field name="model">hospital.patient</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">om_hospital.patient_details__id_report</field>
        <field name="report_file">om_hospital.patient_details__id_report</field>
        <field name="print_report_name">'Patient Details - ' + object.name</field>
        <field name="binding_model_id" ref="model_hospital_patient"/>
        <field name="binding_type">report</field>
    </record>

    <record id="patient_card_action_report" model="ir.actions.report">
        <field name="name">Patient Card</field>
        <field name="model">hospital.patient</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">om_hospital.patient_card__id_report</field>
        <field name="report_file">om_hospital.patient_card__id_report</field>
        <field name="print_report_name">'Patient Card - ' + object.name</field>
        <field name="binding_model_id" ref="model_hospital_patient"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
