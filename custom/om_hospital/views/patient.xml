<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_create_appointment" model="ir.actions.server">
        <field name="name">Create Appointment</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="om_hospital.model_hospital_patient"/>
        <field name="binding_model_id" ref="om_hospital.model_hospital_patient"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action_values = env.ref('om_hospital.create_appointment_wizard_action').read()[0]
                action_values.update({'context': env.context})
                action = action_values
        </field>
    </record>

    <!-- Tree View -->
    <record id="hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients" create="true">
                <!-- Các cột hiển thị -->
                <field name="id"/>
                <field name="reference"/>
                <field name="name" string="Name"/>
                <field name="responsible_id" string="Responsible"/>
                <field name="age" string="Age"/>
                <field name="gender" string="Gender"/>
                <field name="note" string="Description"/>
                <field name="state" string="Status"/>
                <field name="appointment_count" string="Appointment Count"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="hospital_patient_kanban" model="ir.ui.view">
        <field name="name">hospital.patient.kanban</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name" string="Name"/>
                <field name="responsible_id" string="Responsible"/>
                <field name="age" string="Age"/>
                <field name="gender" string="Gender"/>
                <field name="note" string="Description"/>
                <field name="state" string="Status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <ul>
                                    <li>
                                        ID: <field name="id"/>
                                    </li>
                                    <li>
                                        Name: <field name="name"/>
                                    </li>
                                    <li>
                                        Age: <field name="age"/>
                                    </li>
                                    <li>
                                        Gender: <field name="gender"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button id="button_confirm" name="action_confirm" string="Confirm" class="btn-primary" states="draft" confirm="Are you sure that you need to confirm?" type="object" />
                    <button id="button_done" name="action_done" string="Mark As Done" class="btn-primary" states="confirm" type="object" />
                    <button id="button_draft" name="action_draft" string="Set To Draft" class="btn-primary" states="cancel" type="object" />
                    <button id="button_cancel" name="action_cancel" string="Cancel" states="draft,confirm,done" confirm="Are you sure that you need to cancel?" type="object" />
                    <button id="button_create_appointment" name="%(create_appointment_wizard_action)d" string="Create Appointment" class="btn-primary" type="action" />
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done" />
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_appointments" class="oe_stat_button" icon="fa-calendar" type="object">
                            <div class="o_stat_info">
                                <field name="appointment_count" class="o_stat_value" />
                                <span class="o_stat_text">Appointments</span>
                            </div>
                        </button>
                    </div>

                    <field name="image" widget="image" class="oe_avatar" />
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="responsible_id"/>
                        <field name="age"/>
                        <field name="appointment_count"/>
                    </group>
                    <group>
                        <field name="gender" invisible="context.get('hide_gender')"/>
                        <field name="note"/>
                    </group>

                    <notebook>
                        <page name="appointments" string="Appointments">
                            <field name="appointment_ids" readonly="1">
                                <tree create="0" edit="0" delete="0">
                                    <field name="name"/>
                                    <field name="doctor_id" string="Doctor"/>
                                    <field name="patient_id" string="Patient"/>
                                    <field name="age" string="Age" optional="show"/>
                                    <field name="gender" string="Gender" optional="show"/>
                                    <field name="date_appointment" string="Date" optional="show"/>
                                    <field name="date_checkup" string="Check Up Time" optional="hide"/>
                                    <field name="state" string="Status" optional="show"/>
                                    <field name="note" string="Description" optional="hide"/>
                                </tree>

                                <form>
                                    <div class="oe_title">
                                        <h1>
                                            <field name="name" readonly="1"/>
                                        </h1>
                                    </div>

                                    <group>
                                        <group>
                                            <field name="patient_id"/>
                                            <field name="age"/>
                                            <field name="gender" readonly="1" force_save="1"/>
                                        </group>
                                        <group>
                                            <field name="doctor_id"/>
                                            <field name="date_appointment"/>
                                            <field name="date_checkup"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="hospital_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Patients">
                <field name="name"/>
                <field name="note"/>
                <separator />

                <!-- Filters -->
                <filter name="male" string="Male" domain="[('gender', '=', 'male')]"/>
                <filter name="female" string="Female" domain="[('gender', '=', 'female')]"/>
                <filter name="other" string="Other" domain="[('gender', '=', 'other')]"/>

                <group expand="1" string="Group By">
                    <filter string="Gender" name="gender" context="{'group_by': 'gender'}"/>
                    <filter string="Patient Name" name="patient_name" context="{'group_by': 'name'}"/>
                    <filter string="Responsible" name="responsible_id" context="{'group_by': 'responsible_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="patient_action" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_responsible_id': 1, 'search_default_male': 1}</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient!
            </p>
        </field>
    </record>

    <menuitem id="hospital_root" name="Hospital" sequence="10" />

    <menuitem id="hospital_patient_root" name="Patients" parent="hospital_root" sequence="10" />

    <menuitem id="hospital_patient" name="Patients" parent="hospital_patient_root" action="patient_action" sequence="10" />
</odoo>
