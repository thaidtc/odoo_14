<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="patient_kid_action" model="ir.actions.act_window">
        <field name="name">Kids</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{}</field>
        <field name="domain">[('age','&lt;=', 18)]</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient!
            </p>
        </field>
    </record>

    <menuitem id="hospital_patient_kid" name="Kids" parent="hospital_patient_root" action="patient_kid_action" sequence="20" />
</odoo>
