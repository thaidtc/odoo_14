<?xml version="1.0"?>
<odoo>
    <record id="search_appointment_wizard_form" model="ir.ui.view">
        <field name="name">search.appointment.wizard.form</field>
        <field name="model">search.appointment.wizard</field>
        <field name="arch" type="xml">
            <form string="Search Appointment">
                <group>
                    <field name="patient_id"/>
                </group>
                <footer>
                    <button name="search_appointment_action_m1" type="object" string="Search Appointments (M1)" class="btn-primary"/>
                    <button name="search_appointment_action_m2" type="object" string="Search Appointments (M2)" class="btn-primary"/>
                    <button name="search_appointment_action_m3" type="object" string="Search Appointments (M3)" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/> 
                </footer>
            </form>
        </field>
    </record>

    <record id="search_appointment_wizard_action" model="ir.actions.act_window">
        <field name="name">Search Appointment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">search.appointment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="search_appointment_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
